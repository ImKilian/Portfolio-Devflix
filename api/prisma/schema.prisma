generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Media {
  id        Int       @id @default(autoincrement())
  title     String
  img       String
  type      String
  createdAt DateTime  @default(now())
}

model Projet {
  id           Int            @id @default(autoincrement())
  title        String
  img          String
  description  String
  githubUrl    String?
  technologies ProjetTechno[]
  createdAt    DateTime       @default(now())
}

model Techno {
  id      Int            @id @default(autoincrement())
  name    String         @unique
  icon    String
  projets ProjetTechno[]
}

model ProjetTechno {
  projetId Int
  technoId Int
  projet   Projet @relation(fields: [projetId], references: [id], onDelete: Cascade)
  techno   Techno @relation(fields: [technoId], references: [id])

  @@id([projetId, technoId])
}

model Skill {
  id       Int    @id @default(autoincrement())
  name     String @unique
  icon     String
  category String
}
